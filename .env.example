# Twilio Configuration for Notification Service
# Sign up at https://www.twilio.com/ to get your credentials
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Nodemailer / Email Configuration (Gmail Recommended)
# 1. Go to your Google Account -> Security -> 2-Step Verification
# 2. Scroll to bottom -> App Passwords
# 3. Create a new App Password for "Mail"
# 4. Paste the 16-character password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_16_character_app_password

# NOTE: If you don't provide these, the app will gracefully fall back to 
# logging "MOCK EMAIL" and "MOCK SMS" in the docker logs of the notification-service.
